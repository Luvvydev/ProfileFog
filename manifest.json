{
  "manifest_version": 3,
  "name": "ProfileFog",
  "version": "1.6.0",
  "description": "Chrome MV3 extension for controlled browsing noise, tracker learning, seed rules, page controls, and privacy settings.",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "privacy",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "ProfileFog",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "tracker_rules",
        "enabled": false,
        "path": "rules/tracker_rules.json"
      },
      {
        "id": "cleanup_rules",
        "enabled": false,
        "path": "rules/cleanup_rules.json"
      }
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}